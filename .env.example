# ─────────────────────────────────────────────────────────────────────────────
# Vigilant-X — Environment Variables Template
# Copy this file to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Active provider: groq | openai | anthropic
LLM_PROVIDER=groq

# Groq (testing / default)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# OpenAI (production swap-in)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic (production swap-in)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── Neo4j (CPG Store) ─────────────────────────────────────────────────────────
# For testing, docker-compose spins up a local Neo4j container.
# Set USE_LOCAL_NEO4J=true to connect to localhost:7687 instead of Aura.
USE_LOCAL_NEO4J=true

# Local (docker-compose) — ports remapped to avoid clash with system Neo4j on 7474/7687
NEO4J_LOCAL_URI=bolt://localhost:7688
NEO4J_LOCAL_USERNAME=neo4j
NEO4J_LOCAL_PASSWORD=vigilant_local

# Password used by docker-compose for the local Neo4j service (leave empty to use default)
NEO4J_PASSWORD=

# Aura (production)
NEO4J_AURA_URI=
NEO4J_AURA_USERNAME=
NEO4J_AURA_PASSWORD=
NEO4J_AURA_DATABASE=

# ── GitHub Integration ────────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
# Target repo in "owner/repo" format for dry-run mode
GITHUB_REPO=

# ── Sandbox & Analysis ───────────────────────────────────────────────────────
SANDBOX_TIMEOUT_SECONDS=120
LIBFUZZER_TIMEOUT_SECONDS=60
# Max memory for Z3 solver (MB) — prevents OOM in container
Z3_MEMORY_LIMIT_MB=2048
# Docker image used for the sandbox (built from ./Dockerfile)
SANDBOX_IMAGE=vigilant-x-sandbox:latest

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
