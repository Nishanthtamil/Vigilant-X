# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: groq | openai | anthropic
LLM_PROVIDER=groq

# Groq (default) — get a free key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# OpenAI (fallback) — only needed if LLM_PROVIDER=openai or as fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic (fallback) — only needed if LLM_PROVIDER=anthropic or as fallback
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── Neo4j ─────────────────────────────────────────────────────────────────────
# For local development with docker-compose, leave these as-is.
USE_LOCAL_NEO4J=true
NEO4J_LOCAL_URI=bolt://localhost:7688
NEO4J_LOCAL_USERNAME=neo4j
NEO4J_LOCAL_PASSWORD=vigilant_local

# Neo4j Aura (cloud) — only needed if USE_LOCAL_NEO4J=false
NEO4J_AURA_URI=
NEO4J_AURA_USERNAME=neo4j
NEO4J_AURA_PASSWORD=
NEO4J_AURA_DATABASE=neo4j

# ── GitHub Integration ────────────────────────────────────────────────────────
# Required for posting PR comments. Generate at https://github.com/settings/tokens
# Needs: repo, pull_requests scopes
GITHUB_TOKEN=
GITHUB_REPO=owner/repo-name

# ── Sandbox ───────────────────────────────────────────────────────────────────
SANDBOX_IMAGE=vigilant-x-sandbox:latest
SANDBOX_TIMEOUT_SECONDS=120
LIBFUZZER_TIMEOUT_SECONDS=60
Z3_MEMORY_LIMIT_MB=2048

# Set to true to run sandbox even in --dry-run mode
SANDBOX_ALWAYS_RUN=false

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
